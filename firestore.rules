rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Phase 2 & 4: Validation Blueprints
    function isValidJournalEntry(data) {
      return data.keys().hasAll(['userId', 'mediaUrl', 'mediaType', 'title', 'streak', 'marketCondition', 'expectationFulfilled', 'createdAt', 'updatedAt']) 
        && data.keys().size() >= 9 && data.keys().size() <= 11
        && data.userId == request.auth.uid // Identity Integrity
        && data.mediaUrl is string && data.mediaUrl.size() <= 1000
        && data.mediaType in ['image', 'video']
        && data.title is string && data.title.size() <= 200
        && data.streak in ['losing', 'winning', 'none']
        && data.marketCondition in ['buy-side', 'sell-side', 'ranging', 'choppy']
        && data.expectationFulfilled is bool
        && (data.get('notes', '') is string && data.get('notes', '').size() <= 2000)
        && (data.get('tags', []) is list && data.get('tags', []).size() <= 20)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /journal_entries/{entryId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid && isValidId(entryId);
      
      // Secure List Query: MUST explicitely evaluate resource.data to prevent query scraping.
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() 
        && isValidId(entryId)
        && isValidJournalEntry(incoming())
        // Enforce strict keys during create
        && incoming().keys().hasOnly(['userId', 'mediaUrl', 'mediaType', 'title', 'notes', 'streak', 'marketCondition', 'expectationFulfilled', 'tags', 'createdAt', 'updatedAt']);

      allow update: if isSignedIn() 
        && isValidId(entryId)
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId // Immortal Field
        && incoming().createdAt == existing().createdAt // Immortal Field
        && isValidJournalEntry(incoming())
        && (
           incoming().diff(existing()).affectedKeys().hasOnly([
             'mediaUrl', 'mediaType', 'title', 'notes', 'streak', 'marketCondition', 'expectationFulfilled', 'tags', 'updatedAt'
           ])
        );

      allow delete: if isSignedIn() 
        && isValidId(entryId)
        && existing().userId == request.auth.uid;
    }
  }
}
